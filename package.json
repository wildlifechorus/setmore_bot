{
  "name": "setmore_bot",
  "version": "1.0.0",
  "description": "WhatsApp bot that monitors Setmore calendar for cancellations and posts to a group",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "postinstall": "npm rebuild better-sqlite3",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src --ext .ts",
    "test": "tsx --test src/monitor/intervals.test.ts",
    "type-check": "tsc --noEmit",
    "list-groups": "tsx src/scripts/list-groups.ts",
    "simulate": "tsx src/scripts/simulate-cancellation.ts",
    "simulate:send": "tsx src/scripts/simulate-cancellation.ts --send",
    "check-group": "tsx src/scripts/check-group.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.7",
    "node-fetch": "2.7.0",
    "node-ical": "^0.19.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/node-fetch": "^2.6.13",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
