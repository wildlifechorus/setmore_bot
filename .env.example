# ============================================================
# Setmore Calendar Cancellation Monitor Bot — environment config
# Copy this file to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
# Notification channels
# ----------------------------------------------------------
# At least ONE channel must be configured. A channel is enabled automatically
# when its variables are present:
#   - WhatsApp: WHATSAPP_GROUP_ID
#   - Telegram: TELEGRAM_BOT_TOKEN + TELEGRAM_CHANNEL_ID
# When both are configured, notifications are sent to both (best-effort).

# --- WhatsApp (whatsapp-web.js) ---

# WhatsApp group ID to post notifications to.
# Format: <number>-<timestamp>@g.us
# Obtain this by running: yarn list-groups
WHATSAPP_GROUP_ID=

# Directory where the WhatsApp session is persisted across restarts.
# Losing this directory forces a new QR-code scan.
# Default: ./data/wwebjs_auth
WHATSAPP_SESSION_PATH=./data/wwebjs_auth

# --- Telegram (node-telegram-bot-api) ---

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Target channel ID: @yourchannel (public) or -100... numeric ID (private).
TELEGRAM_CHANNEL_ID=

# ----------------------------------------------------------
# Calendar
# ----------------------------------------------------------

# Setmore iCal feed URL (found in Setmore → Integrations → iCal).
CALENDAR_URL=

# How often to check the calendar for changes (milliseconds).
# Default: 60000 (1 minute)
CHECK_INTERVAL_MS=60000

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------

# Path to the SQLite file used to track seen appointments.
# Default: ./data/appointments.db
DATABASE_PATH=./data/appointments.db
